---
import Layout from "../layouts/Layout.astro";
import Rates from "../components/Rates.astro";
---

<Layout
  title="Golf Rates | Edmonton Springs Golf Course"
  description="View full Edmonton Springs Golf Course rates for 18 holes, 9 holes, cart rental, and driving range buckets."
>
  <Rates />

  <section class="bg-cream pb-16 sm:pb-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700 shadow-soft sm:p-6 sm:text-base">
        <p>
          Fees can vary by booking time and availability. For live tee time pricing, use the booking tool.
        </p>
        <a
          href="https://edmontonsprings.cps.golf/onlineresweb/search-teetime?TeeOffTimeMin=0&TeeOffTimeMax=23"
          target="_blank"
          rel="noreferrer noopener"
          class="mt-4 inline-flex rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
        >
          Go To Booking
        </a>
      </div>
    </div>
  </section>
</Layout>
