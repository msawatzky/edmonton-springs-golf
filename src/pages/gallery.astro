---
import Layout from "../layouts/Layout.astro";

const photos = [
  {
    src: "https://static.wixstatic.com/media/4e1033_1487b68f3c4142999d43a7a1da098c00~mv2.jpg/v1/fill/w_566,h_398,al_c,q_80,usm_0.66_1.00_0.01/4e1033_1487b68f3c4142999d43a7a1da098c00~mv2.jpg",
    alt: "Aerial view of Edmonton Springs Golf Course"
  },
  {
    src: "https://static.wixstatic.com/media/4e1033_389d596e6e314cfab11c6100152d4a11~mv2.jpg/v1/fill/w_1200,h_654,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/Green%2018%20toward%2010.jpg",
    alt: "Green 18 toward 10 at Edmonton Springs"
  },
];
---

<Layout
  title="Photo Gallery | Edmonton Springs Golf Course"
  description="Photos from Edmonton Springs Golf Course in Spruce Grove, Alberta."
>
  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Course</p>
      <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Photo Gallery</h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
        A look at the course, greens, and surroundings at Edmonton Springs.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {photos.map((photo) => (
          <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-soft">
            <img
              src={photo.src}
              alt={photo.alt}
              class="h-56 w-full object-cover transition duration-300 hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
