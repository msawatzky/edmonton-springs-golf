---
import Layout from "../layouts/Layout.astro";
import { galleryPhotos } from "../data/gallery";
---

<Layout
  title="Photo Gallery | Edmonton Springs Golf Course"
  description="Photos from Edmonton Springs Golf Course in Spruce Grove, Alberta."
>
  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Course</p>
      <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Photo Gallery</h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
        A look at the course, greens, and surroundings at Edmonton Springs. Click any photo to view it larger.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {galleryPhotos.map((photo, index) => (
          <button
            type="button"
            class="group overflow-hidden rounded-xl border border-slate-200 bg-white text-left shadow-soft transition hover:border-pine-700/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pine-700"
            data-gallery-open={index}
            aria-label={`View larger: ${photo.alt}`}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="h-56 w-full object-cover transition duration-300 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <dialog
    id="gallery-lightbox"
    class="fixed inset-0 z-50 m-0 h-full w-full max-h-none max-w-none border-0 bg-transparent p-4 backdrop:bg-black/85 open:flex open:items-center open:justify-center"
    aria-label="Photo gallery viewer"
  >
    <div class="relative flex max-h-[92vh] w-full max-w-6xl items-center justify-center">
      <button
        type="button"
        data-gallery-prev
        class="absolute left-0 top-1/2 z-10 -translate-y-1/2 rounded-full border border-white/30 bg-black/40 p-3 text-white transition hover:bg-black/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:left-2"
        aria-label="Previous photo"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 0 1-.02 1.06L8.832 10l3.938 3.71a.75.75 0 1 1-1.04 1.08l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 0 1 1.06.02Z" clip-rule="evenodd" />
        </svg>
      </button>

      <img
        id="gallery-lightbox-image"
        alt=""
        class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl"
        decoding="async"
      />

      <button
        type="button"
        data-gallery-next
        class="absolute right-0 top-1/2 z-10 -translate-y-1/2 rounded-full border border-white/30 bg-black/40 p-3 text-white transition hover:bg-black/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:right-2"
        aria-label="Next photo"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z" clip-rule="evenodd" />
        </svg>
      </button>

      <button
        type="button"
        data-gallery-close
        class="absolute right-2 top-2 rounded-full border border-white/30 bg-black/40 px-3 py-2 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-black/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:right-4 sm:top-4"
      >
        Close
      </button>
    </div>
  </dialog>
</Layout>

<script define:vars={{ galleryPhotos }}>
  const dialog = document.getElementById("gallery-lightbox");
  const lightboxImage = document.getElementById("gallery-lightbox-image");
  let currentIndex = 0;

  const showPhoto = (index) => {
    currentIndex = index;
    const photo = galleryPhotos[currentIndex];
    lightboxImage.src = photo.src;
    lightboxImage.alt = photo.alt;

    if (!dialog.open) {
      dialog.showModal();
    }
  };

  const showAdjacent = (delta) => {
    const nextIndex = (currentIndex + delta + galleryPhotos.length) % galleryPhotos.length;
    showPhoto(nextIndex);
  };

  document.querySelectorAll("[data-gallery-open]").forEach((button) => {
    button.addEventListener("click", () => {
      showPhoto(Number(button.dataset.galleryOpen));
    });
  });

  document.querySelector("[data-gallery-close]")?.addEventListener("click", () => {
    dialog.close();
  });

  document.querySelector("[data-gallery-prev]")?.addEventListener("click", () => {
    showAdjacent(-1);
  });

  document.querySelector("[data-gallery-next]")?.addEventListener("click", () => {
    showAdjacent(1);
  });

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  dialog?.addEventListener("keydown", (event) => {
    if (event.key === "ArrowLeft") {
      showAdjacent(-1);
    }
    if (event.key === "ArrowRight") {
      showAdjacent(1);
    }
  });
</script>
