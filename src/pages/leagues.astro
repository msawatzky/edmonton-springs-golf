---
import Layout from "../layouts/Layout.astro";

const leagues = [
  {
    label: "Men's League",
    href: "https://www.edmontonspringsgolf.com/mens-league",
    description: "League details, events, and updates for men's play at Edmonton Springs.",
    image:
      "https://images.unsplash.com/photo-1629673120178-53a664eec9e8?w=900&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8N3x8bWVuJTIwZ29sZmluZ3xlbnwwfHwwfHx8MA%3D%3D"
  },
  {
    label: "Ladies League",
    href: "https://www.edmontonspringsgolf.com/ladies-league",
    description: "Schedules and announcements for ladies league nights and activities.",
    image: "https://images.pexels.com/photos/35320701/pexels-photo-35320701.jpeg"
  }
];
---

<Layout
  title="Leagues & Events | Edmonton Springs Golf Course"
  description="Find league and tournament information for Edmonton Springs Golf Course."
>
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Leagues & Events</p>
      <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Join The Competition</h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
        League information is split into dedicated pages for faster access to updates and schedules.
      </p>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        {leagues.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer"
            class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-soft transition hover:-translate-y-0.5 hover:border-clubred-700"
          >
            <img
              src={item.image}
              alt={item.label}
              class="h-44 w-full object-cover transition duration-200 group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">League</p>
              <h2 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900">{item.label}</h2>
              <p class="mt-3 text-sm leading-relaxed text-slate-700">{item.description}</p>
              <span class="mt-5 inline-flex rounded-md bg-pine-900 px-4 py-2 text-xs font-bold uppercase tracking-wide text-white group-hover:bg-clubred-700">
                Open League Page
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 rounded-xl border border-slate-200 bg-cream p-5 sm:p-6">
        <p class="text-sm text-slate-700">
          Need a tee time before league play? Use the booking tool below.
        </p>
        <a
          href="https://edmontonsprings.cps.golf/onlineresweb/search-teetime?TeeOffTimeMin=0&TeeOffTimeMax=23"
          target="_blank"
          rel="noreferrer noopener"
          class="mt-4 inline-flex rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
        >
          Book Tee Time
        </a>
      </div>
    </div>
  </section>
</Layout>
