  { hole: 2, blue: 407, white: 387, red: 357, menHcp: 7, ladiesHcp: 7, menPar: 4, ladiesPar: 4 },
  { hole: 3, blue: 516, white: 490, red: 455, menHcp: 2, ladiesHcp: 2, menPar: 5, ladiesPar: 5 },
  { hole: 4, blue: 380, white: 368, red: 309, menHcp: 8, ladiesHcp: 8, menPar: 4, ladiesPar: 4 },
  { hole: 5, blue: 330, white: 314, red: 273, menHcp: 12, ladiesHcp: 12, menPar: 4, ladiesPar: 4 },
  { hole: 6, blue: 180, white: 170, red: 130, menHcp: 16, ladiesHcp: 16, menPar: 3, ladiesPar: 3 },
  { hole: 7, blue: 433, white: 401, red: 361, menHcp: 10, ladiesHcp: 10, menPar: 4, ladiesPar: 4 },
  { hole: 8, blue: 180, white: 165, red: 139, menHcp: 15, ladiesHcp: 15, menPar: 3, ladiesPar: 3 },
  { hole: 9, blue: 568, white: 550, red: 472, menHcp: 3, ladiesHcp: 3, menPar: 5, ladiesPar: 5 },
  { hole: 10, blue: 502, white: 438, red: 335, menHcp: 13, ladiesHcp: 13, menPar: 5, ladiesPar: 5 },
  { hole: 11, blue: 201, white: 178, red: 122, menHcp: 17, ladiesHcp: 17, menPar: 3, ladiesPar: 3 },
  { hole: 12, blue: 401, white: 364, red: 336, menHcp: 9, ladiesHcp: 9, menPar: 4, ladiesPar: 4 },
  { hole: 13, blue: 196, white: 158, red: 116, menHcp: 18, ladiesHcp: 18, menPar: 3, ladiesPar: 3 },
  { hole: 14, blue: 346, white: 316, red: 291, menHcp: 11, ladiesHcp: 11, menPar: 4, ladiesPar: 4 },
  { hole: 15, blue: 567, white: 511, red: 465, menHcp: 5, ladiesHcp: 5, menPar: 5, ladiesPar: 5 },
  { hole: 16, blue: 540, white: 457, red: 421, menHcp: 1, ladiesHcp: 1, menPar: 4, ladiesPar: 4 },
  { hole: 17, blue: 198, white: 180, red: 150, menHcp: 14, ladiesHcp: 14, menPar: 3, ladiesPar: 3 },
  { hole: 18, blue: 505, white: 465, red: 410, menHcp: 6, ladiesHcp: 6, menPar: 5, ladiesPar: 5 }
];

const totals = {
  out: { blue: 3552, white: 3368, red: 2982, par: 37 },
  in: { blue: 3456, white: 3067, red: 2646, par: 36 },
