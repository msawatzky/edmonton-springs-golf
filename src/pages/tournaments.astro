---
import Layout from "../layouts/Layout.astro";

const tournamentCoordinatorName = "Tim Pedrick";
const tournamentCoordinatorEmail = "tim@edmontonspringsgolf.com";
---

<Layout
  title="Tournaments | Edmonton Springs Golf Course"
  description="Host your next golf tournament at Edmonton Springs — charity outings, corporate events, club competitions, and more. Contact Tim Pedrick for details."
>
  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl space-y-8 px-4 sm:px-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Tournaments</p>
        <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Host Your Event With Us</h1>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
          Edmonton Springs is a great place to bring your group together for a day on the course. Whether you are planning
          a charity fundraiser, a corporate outing, a club championship, or a casual scramble with friends, our team can
          help you put together an event that runs smoothly from first tee to final putt.
        </p>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
          Located just west of Edmonton in Spruce Grove, we offer a welcoming setting, strong course conditions, and
          friendly service that keeps the focus on great golf and a good time for every player in your group.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Events We Host</h2>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700 sm:text-base">
            <li>Charity and fundraising tournaments</li>
            <li>Corporate and team-building outings</li>
            <li>Club championships and member events</li>
            <li>Scrambles, shambles, and social golf days</li>
            <li>League finals and season-end celebrations</li>
          </ul>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Planning Your Day</h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-700 sm:text-base">
            Every tournament is a little different. Tell us about your group size, preferred date, format, and any special
            requests, and we will walk you through the options available for tee times, on-course setup, and event
            coordination.
          </p>
          <p class="mt-4 text-sm leading-relaxed text-slate-700 sm:text-base">
            Specific tournament dates, formats, and registration details will be posted here when they are confirmed.
            For the most up-to-date information, contact Tim Pedrick, our Tournament Coordinator.
          </p>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Get In Touch</p>
        <h2 class="mt-2 font-display text-2xl font-bold uppercase text-pine-900 sm:text-3xl">Contact Our Tournament Coordinator</h2>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">
          Interested in hosting a tournament at Edmonton Springs? Contact {tournamentCoordinatorName} to discuss availability,
          pricing, and how we can help make your event a success.
        </p>
        <div class="mt-5 space-y-2 text-sm text-slate-700 sm:text-base">
          <p><span class="font-semibold text-slate-900">Tournament Coordinator:</span> {tournamentCoordinatorName}</p>
          <p>
            <span class="font-semibold text-slate-900">Email:</span>
            <a href={`mailto:${tournamentCoordinatorEmail}`} class="text-clubred-700 hover:text-clubred-500">
              {tournamentCoordinatorEmail}
            </a>
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={`mailto:${tournamentCoordinatorEmail}?subject=Tournament%20Inquiry`}
            class="rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
          >
            Email Tim
          </a>
          <a
            href="/contact"
            class="rounded-md border border-pine-700 px-5 py-3 text-sm font-bold uppercase tracking-wide text-pine-800 hover:bg-pine-50"
          >
            General Contact
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
