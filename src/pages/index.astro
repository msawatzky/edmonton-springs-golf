---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const bookingUrl =
  "https://edmontonsprings.cps.golf/onlineresweb/search-teetime?TeeOffTimeMin=0&TeeOffTimeMax=23";
---

<Layout
  title="Edmonton Springs Golf Course | Spruce Grove"
  description="Book Edmonton Springs Golf Course tee times, view rates, and find course details from a fast mobile-friendly homepage."
>
  <Hero />

  <section id="booking" class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-soft sm:p-6">
        <div class="mb-4 flex flex-col gap-3 sm:mb-5 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Tee Time Booking</p>
            <h2 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Book On Site</h2>
          </div>
          <a
            href={bookingUrl}
            target="_blank"
            rel="noreferrer noopener"
            class="inline-flex items-center justify-center rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
          >
            Open Full Booking Page
          </a>
        </div>
        <p class="mb-4 text-sm text-slate-700">
          Use the embedded booking tool below. If it does not load on your device, use "Open Full Booking Page".
        </p>
        <div class="overflow-hidden rounded-xl border border-slate-200">
          <iframe
            src={bookingUrl}
            title="Edmonton Springs tee time booking"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            class="h-[820px] w-full bg-white"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-pine-900 py-16 text-white sm:py-20">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-200">Plan Your Visit</p>
        <h2 class="mt-2 font-display text-3xl font-bold uppercase sm:text-4xl">Everything In One Place</h2>
        <p class="mt-4 text-sm leading-relaxed text-slate-100 sm:text-base">
          Long-form content now lives on dedicated pages, making it easier to find detailed league information,
          memberships, full pricing, booking, and directions.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <a href="/course" class="rounded-md border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold uppercase tracking-wide text-white hover:bg-white/20">Course Info</a>
          <a href="/membership" class="rounded-md border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold uppercase tracking-wide text-white hover:bg-white/20">Membership</a>
          <a href="/leagues" class="rounded-md border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold uppercase tracking-wide text-white hover:bg-white/20">Leagues & Events</a>
          <a href="/contact" class="rounded-md border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold uppercase tracking-wide text-white hover:bg-white/20">Contact & Directions</a>
        </div>
      </div>
      <img
        src="https://static.wixstatic.com/media/4e1033_1487b68f3c4142999d43a7a1da098c00~mv2.jpg/v1/fill/w_566,h_398,al_c,q_80,usm_0.66_1.00_0.01/4e1033_1487b68f3c4142999d43a7a1da098c00~mv2.jpg"
        alt="Edmonton Springs golf course scenic shot"
        class="h-72 w-full rounded-xl border border-white/20 object-cover shadow-soft sm:h-80"
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Contact Us</p>
        <h2 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Visit Edmonton Springs</h2>
        <div class="mt-6 grid gap-6 text-sm text-slate-700 sm:grid-cols-2 sm:text-base">
          <div>
            <p class="font-semibold text-slate-900">Edmonton Springs Golf Course</p>
            <p>#9-53302 Range Road 264</p>
            <p>Spruce Grove, AB T7X 3H5</p>
            <p class="mt-2">5 minutes West of Edmonton, 5 minutes East of Spruce Grove.</p>
          </div>
          <div>
            <p><span class="font-semibold text-slate-900">Phone:</span> (780) 962-6500</p>
            <p class="mt-2">
              <span class="font-semibold text-slate-900">Directions:</span> 1 km north of Yellowhead on highway 44,
              right on Township Rd 532A, left on RR 264.
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              <a href="/contact" class="rounded-md bg-pine-700 px-4 py-2 text-sm font-semibold uppercase tracking-wide text-white hover:bg-pine-900">
                Full Contact Page
              </a>
              <a
                href={bookingUrl}
                target="_blank"
                rel="noreferrer noopener"
                class="rounded-md border border-clubred-700 px-4 py-2 text-sm font-semibold uppercase tracking-wide text-clubred-700 hover:bg-clubred-100"
              >
                Book a Tee Time
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
