---
import Layout from "../layouts/Layout.astro";

const instructionBookingUrl =
  "https://app.swingmatchgolf.com/my/instructors/jack-rea-hf4d?utm_source=qr_code";
const jackReaEmail = "jack@edmontonspringsgolf.com";
---

<Layout
  title="Instruction | Edmonton Springs Golf Course"
  description="Golf instruction at Edmonton Springs — Youth on the Course junior programs and PGA of Canada pro lessons in Spruce Grove."
>
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Instruction</p>
        <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Lessons & Programs</h1>
        <p class="mt-4 text-sm leading-relaxed text-slate-700 sm:text-base">
          Whether you are brand new to the game or looking to sharpen your skills, Edmonton Springs offers instruction for all ages and levels.
        </p>
      </div>
      <img
        src="/images/driving-range.jpg"
        alt="Driving range at Edmonton Springs Golf Course"
        class="h-72 w-full rounded-xl border border-slate-200 object-cover shadow-soft sm:h-80"
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl space-y-8 px-4 sm:px-6">
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-soft">
        <div class="grid lg:grid-cols-2">
          <img
            src="/images/island-green.jpg"
            alt="Island green at Edmonton Springs Golf Course"
            class="h-56 w-full object-cover sm:h-72 lg:h-full lg:min-h-[420px]"
            loading="lazy"
            decoding="async"
          />
          <div class="p-6 sm:p-8">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Junior Golf</p>
            <h2 class="mt-2 font-display text-2xl font-bold uppercase text-pine-900 sm:text-3xl">Youth on Course</h2>
            <p class="mt-4 text-sm leading-relaxed text-slate-700 sm:text-base">
              Youth on Course is a national program led by Golf Canada that helps juniors aged 6–18 play affordable golf at
              participating courses across Canada, the United States, and Australia. Through Golf Canada's partnership with
              Youth on Course, members can access rounds for $5 or less during designated times at participating facilities.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700 sm:text-base">
              Juniors join through a Golf Canada membership, which includes Youth on Course access. Members complete the
              program curriculum, follow course-specific booking rules, and can use the Youth on Course app to find
              participating clubs and available tee times.
            </p>

            <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700 sm:text-base">
              <li class="ml-5 list-disc">Eligible ages 6–18 (through age 18; valid until 19th birthday).</li>
              <li class="ml-5 list-disc">Rounds at participating courses for $5 or less during posted Youth on Course times.</li>
              <li class="ml-5 list-disc">Includes benefits through Golf Canada membership, including handicap services for juniors.</li>
              <li class="ml-5 list-disc">Availability and booking rules vary by course — call ahead when required.</li>
            </ul>

            <div class="mt-6 rounded-lg border border-slate-200 bg-cream p-4">
              <p class="text-sm font-semibold text-slate-900">Youth on Course at Edmonton Springs</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-700">
                Edmonton Springs participates in Youth on Course. Program rates and tee-time availability here are separate
                from our regular green fee schedule. Contact the Pro Shop for current Youth on Course pricing and booking
                details at our course.
              </p>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href="/contact"
                class="rounded-md bg-pine-900 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-pine-700"
              >
                Contact Pro Shop
              </a>
              <a
                href="https://www.golfcanada.ca/youthoncourse/"
                target="_blank"
                rel="noreferrer noopener"
                class="rounded-md border border-pine-700 px-5 py-3 text-sm font-bold uppercase tracking-wide text-pine-800 hover:bg-pine-50"
              >
                Golf Canada — Youth on Course
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-soft">
        <div class="grid lg:grid-cols-2">
          <div class="p-6 sm:p-8 lg:order-1">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Private Instruction</p>
            <h2 class="mt-2 font-display text-2xl font-bold uppercase text-pine-900 sm:text-3xl">A Message from Our PGA of Canada Pro</h2>
            <p class="mt-4 text-sm leading-relaxed text-slate-700 sm:text-base">
              My name is Jack Rea and I am a PGA of Canada golf professional with a background in competitive sports, including college baseball, which shaped my approach to teaching the game. I like to keep instruction simple, and tailor each lesson to player's individual needs whether you're just getting started or looking to fine-tune your skills.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700 sm:text-base">
              My goal is to create a relaxed environment for you, whether it's an hour lesson on the range, putting green, or an on-course lesson. Looking forward to seeing you this summer!
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={instructionBookingUrl}
                target="_blank"
                rel="noreferrer noopener"
                class="rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
              >
                Book a Lesson
              </a>
              <a
                href={`mailto:${jackReaEmail}`}
                class="rounded-md border border-pine-700 px-5 py-3 text-sm font-bold uppercase tracking-wide text-pine-800 hover:bg-pine-50"
              >
                Contact Jack
              </a>
            </div>
          </div>
          <img
            src="/images/DJI_0268.JPG"
            alt="Golfers on the course at Edmonton Springs"
            class="h-56 w-full object-cover sm:h-72 lg:order-2 lg:h-full lg:min-h-[420px]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
