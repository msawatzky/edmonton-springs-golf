---
import Layout from "../layouts/Layout.astro";

const resources = [
  {
    title: "May 2026 Newsletter",
    description: "Course updates, league news, and seasonal highlights from Edmonton Springs.",
    href: "/documents/May 2026 Newsletter - ESG.pdf",
    label: "Download PDF",
    date: "May 2026"
  }
];
---

<Layout
  title="Contact & Resources | Edmonton Springs Golf Course"
  description="Contact the Edmonton Springs Golf Course Pro Shop, get directions, and download newsletters and course resources."
>
  <section class="bg-cream py-16 sm:py-20">
    <div class="mx-auto max-w-6xl space-y-6 px-4 sm:px-6">

      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">Contact & Resources</p>
        <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">Edmonton Springs Golf Course</h1>
      </div>

      <!-- Contact card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
        <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Get In Touch</h2>
        <div class="mt-6 grid gap-8 text-sm text-slate-700 sm:grid-cols-2 sm:text-base">
          <div>
            <p class="font-semibold text-slate-900">Address</p>
            <p>#9-53302 Range Road 264</p>
            <p>Spruce Grove, AB T7X 3H5</p>
            <p class="mt-3">5 minutes West of Edmonton, 5 minutes East of Spruce Grove.</p>
            <p class="mt-5 font-semibold text-slate-900">Directions</p>
            <p>1 km north of Yellowhead on highway 44, right on Township Rd 532A, left on RR 264.</p>
          </div>
          <div>
            <p><span class="font-semibold text-slate-900">Phone:</span> (780) 962-6500</p>
            <p class="mt-3"><span class="font-semibold text-slate-900">Email:</span> proshop@edmontonspringsgolf.com</p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a
                href="https://edmontonsprings.cps.golf/onlineresweb/search-teetime?TeeOffTimeMin=0&TeeOffTimeMax=23"
                target="_blank"
                rel="noreferrer noopener"
                class="rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700"
              >
                Book Tee Time
              </a>
              <a
                href="https://www.edmontonspringsgolf.com/contact-us"
                target="_blank"
                rel="noreferrer"
                class="rounded-md border border-pine-700 px-5 py-3 text-sm font-bold uppercase tracking-wide text-pine-800 hover:bg-pine-50"
              >
                View On Map
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Resources / Downloads -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
        <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Downloads & Resources</h2>
        <p class="mt-2 text-sm text-slate-700">Newsletters and course documents available to download.</p>

        <ul class="mt-6 space-y-3">
          {resources.map((resource) => (
            <li class="flex items-center justify-between gap-4 rounded-lg border border-slate-200 bg-cream px-5 py-4">
              <div>
                <p class="text-sm font-semibold text-slate-900">{resource.title}</p>
                <p class="mt-0.5 text-xs text-slate-500">{resource.date}</p>
                <p class="mt-1 text-sm text-slate-700">{resource.description}</p>
              </div>
              <a
                href={resource.href}
                target="_blank"
                rel="noreferrer noopener"
                class="shrink-0 rounded-md bg-pine-900 px-4 py-2 text-xs font-bold uppercase tracking-wide text-white hover:bg-pine-700"
              >
                {resource.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>
</Layout>
