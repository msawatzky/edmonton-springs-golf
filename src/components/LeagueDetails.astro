---
import type { LeaguePageData } from "../data/leagues";
import LeagueApplicationModal from "./LeagueApplicationModal.astro";

interface Props {
  league: LeaguePageData;
}

const { league } = Astro.props;

const buttonClasses = {
  primary:
    "rounded-md bg-clubred-500 px-5 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-clubred-700",
  secondary:
    "rounded-md border border-pine-700 px-5 py-3 text-sm font-bold uppercase tracking-wide text-pine-800 hover:bg-pine-50",
  default:
    "rounded-md border border-slate-300 px-5 py-3 text-sm font-bold uppercase tracking-wide text-slate-800 hover:bg-slate-100"
};
---

<section class="bg-cream py-16 sm:py-20">
  <div class="mx-auto max-w-6xl space-y-6 px-4 sm:px-6">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-clubred-700">{league.season}</p>
      <h1 class="mt-2 font-display text-3xl font-bold uppercase text-pine-900 sm:text-4xl">{league.title}</h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-700 sm:text-base">{league.intro}</p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {league.atAGlance.map((item) => (
          <article class="rounded-lg border border-slate-200 bg-cream p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-clubred-700">{item.label}</p>
            <p class="mt-2 text-sm font-semibold text-slate-900 sm:text-base">{item.value}</p>
          </article>
        ))}
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <button
          type="button"
          data-league-apply-open={league.slug}
          class={buttonClasses.primary}
        >
          {league.application.buttonLabel}
        </button>
        {league.ctas.map((cta) => (
          <a
            href={cta.href}
            target={cta.external ? "_blank" : undefined}
            rel={cta.external ? "noreferrer noopener" : undefined}
            class={buttonClasses[cta.variant ?? "default"]}
          >
            {cta.label}
          </a>
        ))}
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Registration Steps</h2>
          <ol class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700 sm:text-base">
            {league.registrationSteps.map((step) => (
              <li class="list-decimal ml-5">{step}</li>
            ))}
          </ol>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Fees & Inclusions</h2>
          <div class="mt-4 space-y-4">
            {league.feeSections.map((section) => (
              <section class="rounded-lg border border-slate-200">
                <div class="border-b border-slate-200 bg-pine-900 px-4 py-3">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-white">{section.title}</h3>
                </div>
                <div class="p-4">
                  {section.note && <p class="mb-3 text-sm text-slate-700">{section.note}</p>}
                  <dl class="space-y-2">
                    {section.rows.map((row) => (
                      <div class="flex items-start justify-between gap-6 border-t border-slate-100 pt-2 first:border-none first:pt-0">
                        <dt class="text-sm font-semibold text-slate-900">{row.label}</dt>
                        <dd class="text-right text-sm font-semibold text-clubred-700">{row.value}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              </section>
            ))}
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Schedule</h2>
          <div class="mt-4 space-y-4">
            {league.scheduleSections.map((section) => (
              <section>
                <h3 class="text-sm font-semibold uppercase tracking-wide text-clubred-700">{section.title}</h3>
                <ul class="mt-2 space-y-2 text-sm leading-relaxed text-slate-700">
                  {section.items.map((item) => (
                    <li class="list-disc ml-5">{item}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">{league.highlightsTitle ?? "Tournament Highlights"}</h2>
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700">
            {league.tournamentHighlights.map((item) => (
              <li class="list-disc ml-5">{item}</li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Policies & Notes</h2>
          <div class="mt-4 space-y-4">
            {league.policies.map((section) => (
              <section>
                <h3 class="text-sm font-semibold uppercase tracking-wide text-clubred-700">{section.title}</h3>
                <ul class="mt-2 space-y-2 text-sm leading-relaxed text-slate-700">
                  {section.items.map((item) => (
                    <li class="list-disc ml-5">{item}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-soft sm:p-6">
          <h2 class="font-display text-2xl font-bold uppercase text-pine-900">Contact</h2>
          <dl class="mt-4 space-y-3">
            {league.contacts.map((item) => (
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-clubred-700">{item.label}</dt>
                <dd class="mt-1 text-sm text-slate-800">
                  {item.value.includes("@") ? <a href={`mailto:${item.value}`} class="hover:text-clubred-700">{item.value}</a> : item.value}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </div>
</section>

<LeagueApplicationModal slug={league.slug} application={league.application} />
